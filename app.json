{
  "expo": {
    "name": "Fluent B2 Coach",
    "slug": "fluent-b2-coach",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#EAF8FF",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.prototype.fluentb2coach"
    },
    "android": {
      "package": "com.prototype.fluentb2coach",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Fluent Coach uses the microphone for voice answers and speaking practice.",
          "recordAudioAndroid": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "1b165541-c962-41cb-bc35-bfc3c3f4d6c8"
      }
    },
    "owner": "matthewbrodek"
  }
}
