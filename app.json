{
  "expo": {
    "name": "English Cat Coach",
    "slug": "english-a2-c1-cat-coach",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#EAF8FF",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.onesh.englishcatcoach"
    },
    "android": {
      "package": "com.onesh.englishcatcoach",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EAF8FF"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "English Cat Coach uses the microphone for voice answers and speaking practice.",
          "recordAudioAndroid": true
        }
      ]
    ]
  }
}
